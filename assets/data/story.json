              "text": "Express disappointment.",
              "effects": {
                "relationships": { "Lucien": -6 },
                "trust": -4,
                "memoryTags": ["disappointed_lucien"]
              },
              "nextScene": "c7s2"
            },
            {
              "text": "Keep the secret to yourself.",
              "effects": {
                "relationships": { "Lucien": 4 },
                "trust": 2,
                "memoryTags": ["kept_secret"]
              },
              "nextScene": "c7s2"
            }
