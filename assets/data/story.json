    {
      "id": "chapter9",
      "title": "Society Watches",
      "scenes": [
        {
          "id": "c9s1",
          "speaker": "Narrator",
          "text": "A scandal rumor spreads, fueled by past pride and misunderstandings.",
          "choices": [
            {
              "text": "Address the town openly.",
              "effects": {
                "reputation": -5,
                "pride": -6,
                "memoryTags": ["open_address"]
              },
              "nextScene": "c9s2"
            },
            {
              "text": "Let the gossip fade.",
              "effects": {
                "reputation": -12,
