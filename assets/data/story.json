              "nextScene": "c4s1"
            },
            {
              "text": "Dismiss the rumors.",
              "effects": {
                "relationships": { "Eleanor": -5 },
                "reputation": -3,
                "memoryTags": ["ignored_eleanor"]
              },
              "nextScene": "c4s1"
            }
          ]
        }
      ]
    },
    {
      "id": "chapter4",
      "title": "The Garden Gathering",
      "scenes": [
        {
          "id": "c4s1",
          "speaker": "Narrator",
          "text": "The town’s finest gather beneath the roses. Dance partners are chosen based on reputation and affection.",
