                "memoryTags": ["danced_theodore"]
              },
              "nextScene": "c4s2"
            },
            {
              "text": "Dance with Lucien.",
              "effects": {
                "relationships": { "Lucien": 10 },
                "reputation": 3,
                "memoryTags": ["danced_lucien"]
              },
              "nextScene": "c4s2"
            },
            {
              "text": "Stay aloof.",
              "effects": {
                "reputation": -2,
                "memoryTags": ["aloof_at_gathering"]
