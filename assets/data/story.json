    {
      "id": "chapter3",
      "title": "Tea, Rumors & Pride",
      "scenes": [
        {
          "id": "c3s1",
          "speaker": "Narrator",
          "text": "Gossip swirls through Rosemere Gardens. Your recent choices have caught many eyes.",
