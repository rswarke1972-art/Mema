            {
              "text": "Embrace the attention.",
              "effects": {
                "reputation": 10,
                "pride": 8,
                "memoryTags": ["pride_rise"]
              },
              "nextScene": "c3s2"
            },
            {
              "text": "Remain humble.",
              "effects": {
                "reputation": 5,
                "pride": -4,
                "memoryTags": ["humble_attitude"]
              },
              "nextScene": "c3s2"
            }
          ]
        },
        {
          "id": "c3s2",
          "speaker": "Eleanor",
          "text": "Mema, I admire your poise, but whispers say you are too proud. How will you respond?",
          "choices": [
            {
              "text": "Acknowledge the concern.",
              "effects": {
                "relationships": { "Eleanor": 7 },
                "reputation": 2,
                "memoryTags": ["elegant_selfawareness"]
