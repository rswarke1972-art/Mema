      "scenes": [
        {
          "id": "c8s1",
          "speaker": "Narrator",
          "text": "Your choices have woven a tapestry of trust, pride, and reputation. The town watches your growth.",
          "choices": [
            {
              "text": "Embrace humility and seek wisdom.",
              "effects": {
                "wisdom": 12,
                "pride": -8,
                "memoryTags": ["humble_growth"]
              },
              "nextScene": "c8s2"
            },
            {
              "text": "Lean into confidence, cherish your status.",
              "effects": {
                "pride": 10,
