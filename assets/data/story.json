      "id": "chapter1",
      "title": "The Matchmaker",
      "scenes": [
        {
          "id": "c1s1",
          "speaker": "Clara",
          "text": "Mema, I have loved you for so long. Should I confess my feelings to Sir Edwin?",
          "choices": [
            {
              "text": "Encourage her confession.",
              "effects": {
                "relationships": { "Clara": 10 },
                "reputation": 5,
                "memoryTags": ["clara_confession_encouraged"]
              },
              "nextScene": "c1s2"
            },
            {
              "text": "Advise patience.",
              "effects": {
                "relationships": { "Clara": 5 },
                "reputation": 2,
                "memoryTags": ["clara_advised_patience"]
              },
              "nextScene": "c1s2"
            },
            {
              "text": "Secretly interfere and discourage her.",
              "effects": {
                "relationships": { "Clara": -8 },
